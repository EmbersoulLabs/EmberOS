# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Billing / export (testing vs production)
# false = 1080p export open to everyone (local testing default)
# true  = 1080p gated behind paid org plans (enable at launch)
EXPORT_PAYWALL=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Vercel / serverless: use the Supabase connection pooler URL (port 6543, NOT 5432)
# with ?pgbouncer=true to enable transaction-mode pooling.
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Worker (Railway): use the direct URL (port 5432, no ?pgbouncer).
DATABASE_URL=

# Redis / Queue
REDIS_URL=redis://localhost:6379
# If you must use Upstash locally, isolate from Railway worker:
# LOCAL_DEV=true
# BULLMQ_PREFIX=local

# LLM
OPENAI_API_KEY=

# Online music library (Jamendo) — optional.
# Get a free client_id at https://devportal.jamendo.com/ to enable online BGM search.
# When unset, the in-app online search is hidden and only the built-in library is used.
JAMENDO_CLIENT_ID=

# Storage
SUPABASE_STORAGE_BUCKET=campaign-assets

# Worker
FFMPEG_PATH=ffmpeg
WORKER_CONCURRENCY=2
# FFmpeg renders are memory-heavy — keep 1 on Railway unless you have ≥2GB RAM
RENDER_CONCURRENCY=1

# Cost guardrails
LLM_BUDGET_PER_TASK_USD=0.50
CEO_MAX_RETRIES=2
