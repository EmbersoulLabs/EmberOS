{
  "name": "@ceo-agent/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --include \"src/**/*\" --include \"../../packages/agents/src/**/*\" --include \"../../packages/shared/src/**/*\" src/index.ts",
    "retry:renders": "tsx scripts/retry-failed-renders.ts",
    "clean:queue": "tsx scripts/clean-queue.ts",
    "refresh:bgm": "tsx scripts/refresh-bgm-assets.ts",
    "curate:bgm": "tsx scripts/curate-commercial-bgm.ts",
    "curate:bgm:cc0": "tsx scripts/curate-cc0-bgm.ts",
    "check:infra": "tsx scripts/check-infra.ts",
    "upload:brand-logo": "tsx scripts/upload-brand-logo.ts",
    "e2e:video-studio": "tsx ../../scripts/e2e-video-studio.ts",
    "start": "node dist/index.js",
    "build": "tsc && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "echo ok"
  },
  "dependencies": {
    "@ceo-agent/agents": "workspace:*",
    "@ceo-agent/db": "workspace:*",
    "@ceo-agent/queue": "workspace:*",
    "@ceo-agent/shared": "workspace:*",
    "archiver": "^7.0.1",
    "bullmq": "^5.34.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "@supabase/supabase-js": "^2.47.10",
    "ioredis": "^5.4.2",
    "tsx": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  }
}
